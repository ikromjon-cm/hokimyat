{
  "name": "uychi-majlis",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:mobile": "npm run dev -w apps/mobile",
    "build": "npm run build -w packages/shared && npm run build -w packages/types && npm run build -w packages/config && npm run build -w packages/ui && npm run build -w apps/backend",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "npm run test -w apps/backend",
    "db:migrate": "npm run db:migrate -w apps/backend",
    "db:seed": "npm run db:seed -w apps/backend",
    "db:studio": "npm run db:studio -w apps/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
