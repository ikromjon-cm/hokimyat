    {
      "name": "Authentication",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/request-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "request-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+998901234567\"\n}"
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+998901234567\",\n  \"code\": \"123456\",\n  \"deviceId\": \"device-001\",\n  \"deviceName\": \"iPhone 15\",\n  \"pushToken\": \"ExponentPushToken[xxxxxxxx]\"\n}"
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}"
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    },
