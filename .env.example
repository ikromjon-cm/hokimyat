# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uychi_majlis?schema=public"

# JWT
JWT_ACCESS_SECRET="your-access-secret-key-at-least-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# Eskiz SMS (optional). Leave ESKIZ_EMAIL/PASSWORD empty to run in demo OTP mode.
ESKIZ_EMAIL="your-eskiz-email"
ESKIZ_PASSWORD="your-eskiz-password"
ESKIZ_API_URL="https://notify.eskiz.uz/api/v1"

# OTP demo mode: when "true", the login code is returned in the API response
# instead of being sent by SMS (no paid SMS provider needed). Auto-enabled when
# no Eskiz credentials are set. Set to "false" to force real SMS.
OTP_DEMO_MODE="true"

# Email (Nodemailer - SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="noreply@uychimajlis.uz"

# Expo Push
EXPO_ACCESS_TOKEN="your-expo-access-token"

# MinIO (optional, for selfie storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minio-admin"
MINIO_SECRET_KEY="minio-password"
MINIO_BUCKET="uychi-majlis-selfies"
MINIO_USE_SSL=false

# Server
PORT=4000
NODE_ENV="development"
API_PREFIX="/api/v1"

# Encryption key for selfie images
SELFIE_ENCRYPTION_KEY="your-32-char-encryption-key-here!!!!"

# CORS
CORS_ORIGIN="*"

# Cluster Mode (production). Set "false" on small/free single-instance hosts.
CLUSTER_ENABLED="true"

# Background jobs (BullMQ reminders/reports). "true" requires a paid/persistent
# Redis. Keep "false" on free Redis (e.g. Upstash) to stay within command limits.
JOBS_ENABLED="false"

# Sentry Error Tracking
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE=1.0

# Prometheus Metrics
METRICS_PREFIX="uychi_majlis"
METRICS_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
MEETING_API_RATE_LIMIT_MAX=30

# Organization defaults
DEFAULT_GEOFENCE_RADIUS=100
CHECK_IN_WINDOW_START="08:00"
CHECK_IN_WINDOW_END="10:00"
CHECK_OUT_WINDOW_START="17:00"
CHECK_OUT_WINDOW_END="19:00"
