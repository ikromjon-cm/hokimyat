# Server
PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1
CORS_ORIGIN=*
CLUSTER_ENABLED=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uychi_majlis?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-to-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_BLOCK_DURATION_MINUTES=15

# SMS (Eskiz.uz)
ESKIZ_EMAIL=your-eskiz-email@example.com
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_API_URL=https://notify.eskiz.uz/api

# Selfie encryption (AES-256-GCM, must be exactly 32 characters)
SELFIE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# QR Code
QR_SECRET=random-64-char-string-for-qr-signing

# Backup
BACKUP_DIR=./backups
RETENTION_DAYS=7

# Monitoring
SENTRY_DSN=
PROMETHEUS_METRICS=false
